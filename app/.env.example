# LLM provider — DashScope (Aliyun) OpenAI-compatible endpoint
# Sign up at https://dashscope.console.aliyun.com → API Keys
ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
ANTHROPIC_API_KEY=sk-your-dashscope-key-here

# Tavily web search — required for real-time data in all modes
# Free tier: 1000 searches/month. Sign up at https://tavily.com → API Keys
# Leave blank to disable (LLM answers from training data only — not recommended)
TAVILY_API_KEY=tvly-your-tavily-key-here

# Rate limiting — requests per IP per hour (localhost is always exempt)
RATE_LIMIT_PER_HOUR=30

# Daily usage cap — logs a warning when exceeded (not a hard stop)
MAX_DAILY_REQUESTS=200

# Per-IP daily limit — set to 5 if deploying a public demo with your own key, 0 to disable
IP_DAILY_LIMIT=0

# Optional — defaults to 3001
PORT=3001
